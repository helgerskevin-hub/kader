{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "FULL hooks preset — combines the bundle's 3 active hooks (SessionStart fingerprint, PreToolUse Bash package guard, PostToolUse pattern quickscan) with the lite SessionEnd 0-day reminder. Merge the 'hooks' block into your project's .claude/settings.json. Adjust paths if you placed the suite somewhere other than skills/Security Assessment/.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/skills/Security Assessment/Security-automated-claude-skills/.claude/hooks/session-start.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/skills/Security Assessment/Security-automated-claude-skills/.claude/hooks/pre-bash-package-guard.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/skills/Security Assessment/Security-automated-claude-skills/.claude/hooks/post-edit-quickscan.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/skills/Security Assessment/install/hooks/session-end-security-0day.sh\""
          }
        ]
      }
    ]
  }
}
