# CTI Search Plugin — Environment Variables
# Copy to .env and fill in your keys

# ── Search Provider ───────────────────────────────────────────────
# Choose one: brave | serpapi | google
SEARCH_PROVIDER=brave

# Brave Search API (recommended — free tier available)
# Get key: https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# SerpAPI (alternative)
# Get key: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Google Custom Search (alternative)
# Get key + CSE ID: https://programmablesearchengine.google.com
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# ── NotebookLM ────────────────────────────────────────────────────
# Your NotebookLM notebook ID (from the URL: notebooklm.google.com/notebook/<id>)
NOTEBOOKLM_NOTEBOOK_ID=
